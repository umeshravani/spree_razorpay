<%
  current_session = Spree::RazorpayCheckout.find_or_initialize_by(order_id: @order.id)
  amount_in_cents = (@order.total_minus_store_credits.to_f * 100).to_i
  
  ::Razorpay.setup(payment_method.current_key_id, payment_method.current_key_secret)
  
  needs_new_order = current_session.new_record? || current_session.razorpay_order_id.blank?
  
  if !needs_new_order
    begin
      rzp_order = ::Razorpay::Order.fetch(current_session.razorpay_order_id)
      if rzp_order.amount != amount_in_cents || rzp_order.status == 'paid'
        needs_new_order = true 
      end
    rescue StandardError => e
      Rails.logger.error("Razorpay Fetch Failed: #{e.message}")
      needs_new_order = true
    end
  end
  
  if needs_new_order
    rzp_order = ::Razorpay::Order.create({
      amount: amount_in_cents, 
      currency: @order.currency || 'INR',
      receipt: @order.number,
      payment_capture: 1,
      notes: {
        spree_order_number: @order.number,
        customer_email: @order.email
      }
    })
    
    current_session.update!(
      razorpay_order_id: rzp_order.id,
      payment_method: payment_method.name,
      status: 'created'
    )
  end
%>

<% if current_session.present? && current_session.razorpay_order_id.present? %>
  
  <div style="display: flex; justify-content: center;">
    <%= image_tag 'payment_icons/window_modal.svg', width: 130, height: 100, class: 'ml-2', alt: 'Razorpay Modal Window' %>
  </div>

  <p style="max-width: 100%; margin: 10px auto; text-align: center; color: var(--color-neutral-600); font-size: 0.9rem; line-height: 1.5;">
    Click <b>Pay</b> below to complete your <br>
    purchase securely via Razorpay. <br>
  </p>

  <div style="display: flex; justify-content: center; align-items: center; margin-bottom: 1rem;">
    <%= payment_method_icon_tag 'visa', class: 'm-1' %>
    <%= payment_method_icon_tag 'master', class: 'm-1' %>
    <%= payment_method_icon_tag 'google_pay', class: 'm-1' %>
    <%= payment_method_icon_tag 'amazon', class: 'm-1' %>
    <%= payment_method_icon_tag 'upi', class: 'm-1' %>
  </div>

  <input type="hidden" name="payment_source[<%= payment_method.id %>][razorpay_payment_id]" id="razorpay_payment_id" value="">
  <input type="hidden" name="payment_source[<%= payment_method.id %>][razorpay_order_id]" id="razorpay_order_id" value="">
  <input type="hidden" name="payment_source[<%= payment_method.id %>][razorpay_signature]" id="razorpay_signature" value="">

  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script>
    (function() {
      if (window.rzpListenerBound) return;
      window.rzpListenerBound = true;

      const RAZORPAY_METHOD_ID = "<%= payment_method.id %>";

      document.addEventListener("click", function(e) {
        const submitBtn = e.target.closest("#checkout-payment-submit") || e.target.closest("button[name='commit']");
        if (!submitBtn) return;

        const form = submitBtn.closest("form");
        if (!form || form.id !== "checkout_form_payment") return;

        const selectedRadio = form.querySelector('input[name="order[payments_attributes][][payment_method_id]"]:checked');
        const fallbackInput = form.querySelector('input[type="hidden"][name="order[payments_attributes][][payment_method_id]"]');
        const selectedValue = selectedRadio ? selectedRadio.value : (fallbackInput ? fallbackInput.value : null);

        if (selectedValue !== RAZORPAY_METHOD_ID) return;

        const paymentIdField = document.getElementById("razorpay_payment_id");
        const signatureField = document.getElementById("razorpay_signature");

        if (paymentIdField && paymentIdField.value && signatureField && signatureField.value) {
          return; 
        }

        e.preventDefault();
        e.stopPropagation();
        e.stopImmediatePropagation();

        submitBtn.disabled = true;
        const originalText = submitBtn.innerText;
        submitBtn.innerText = "Opening Razorpay...";

        const options = {
          key: "<%= payment_method.current_key_id %>",
          order_id: "<%= current_session.razorpay_order_id %>",
          amount: <%= amount_in_cents %>,
          currency: "<%= @order.currency || 'INR' %>",
          name: "<%= payment_method.preferred_merchant_name.presence || 'Razorpay Store' %>",
          description: "<%= payment_method.preferred_merchant_description.presence || 'Order Payment' %>",
          handler: function (response) {
            document.getElementById("razorpay_payment_id").value = response.razorpay_payment_id;
            document.getElementById("razorpay_order_id").value = response.razorpay_order_id;
            document.getElementById("razorpay_signature").value = response.razorpay_signature;

            submitBtn.innerText = "Finalizing...";
            submitBtn.disabled = false;

            HTMLFormElement.prototype.submit.call(form);
          },
          modal: {
            ondismiss: function() {
              submitBtn.disabled = false;
              submitBtn.innerText = originalText;
            }
          },
          prefill: {
            name: "<%= @order.bill_address&.firstname %> <%= @order.bill_address&.lastname %>".trim(),
            email: "<%= @order.email %>",
            contact: "<%= @order.bill_address&.phone %>"
          },
          theme: {
            color: "<%= payment_method.preferred_theme_color.presence || '#2e5bff' %>"
          }
        };

        const rzp = new window.Razorpay(options);
        rzp.open();
      }, { capture: true });
    })();
  </script>

<% else %>
  <div class="alert alert-danger">
    Unable to initialize Razorpay session. Please try again.
  </div>
<% end %>
